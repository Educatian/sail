{
  "name": "sail-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "node --experimental-strip-types tests/traceParser.test.ts",
    "check": "tsc --noEmit",
    "db:init:local": "wrangler d1 execute sail --local --file schema.sql",
    "db:init:remote": "wrangler d1 execute sail --remote --file schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "wrangler": "^4.93.0",
    "typescript": "^5.7.2"
  }
}
